# sendmail-mcp 示例配置
# 建议做法：
# 1. 复制为 .env
# 2. 把下面所有 example / replace_with_* 改成真实值
# 3. 本地终端启动时会自动读取 .env
# 4. MCP 客户端直连 stdio 时，建议在客户端配置里显式传 env，不要只依赖 .env

# SMTP：outlook_send_messages 必填
# 常见示例：
# - Microsoft 365 / Outlook: smtp.office365.com
# - Gmail: smtp.gmail.com
SMTP_HOST=smtp.example.com

# SMTP 认证用户名，通常就是邮箱地址
SMTP_USERNAME=bot@example.com

# SMTP 认证密码或应用专用密码
SMTP_PASSWORD=replace_with_smtp_password

# SMTP 端口
# 当前服务固定使用 465
SMTP_PORT=465

# 可选：发件人地址
# 不填时默认使用 SMTP_USERNAME
# MAIL_FROM=bot@example.com

# IMAP：search/read/draft/send_draft 都依赖
# 常见示例：
# - Microsoft 365 / Outlook: outlook.office365.com
# - Gmail: imap.gmail.com
IMAP_HOST=imap.example.com

# IMAP 端口，默认通常为 993
IMAP_PORT=993

# IMAP 登录用户名，通常就是邮箱地址
IMAP_USERNAME=bot@example.com

# IMAP 登录密码或应用专用密码
IMAP_PASSWORD=replace_with_imap_password

# IMAP 是否使用 SSL
IMAP_USE_SSL=true

# 搜索和读取时访问的文件夹
# 常见值：INBOX、Inbox
IMAP_FOLDER=INBOX

# 草稿与已发送文件夹
# 常见值：
# - Drafts / Sent
# - 草稿 / 已发送邮件
IMAP_DRAFTS_FOLDER=Drafts
IMAP_SENT_FOLDER=Sent

# 可选：收件人白名单
# 不配置时默认允许全部收件人
# 如需限制发送范围，可设置域名或明确邮箱
# ALLOWED_RECIPIENT_DOMAINS=example.com,internal.example.com
# ALLOWED_RECIPIENTS=alice@example.com,bob@example.com
ALLOWED_RECIPIENT_DOMAINS=
ALLOWED_RECIPIENTS=

# 可选：发送限流和单次最大收件人数
RATE_LIMIT_EMAILS_PER_MIN=60
MAX_RECIPIENTS_PER_JOB=1000

# 可选：附件策略
# attachments 传相对路径时，相对 ATTACHMENT_BASE_DIR 解析
# attachments 传绝对路径时，直接按绝对路径读取
# attachments 也支持 file:// URI、data: URI
# 如果希望让 Manus 传可访问的附件 URL，再打开 ALLOW_REMOTE_ATTACHMENTS
# manus-slides://<目录路径> 会先打成 zip 再作为附件发送
ATTACHMENT_BASE_DIR=./attachments
MAX_ATTACHMENT_MB=5
MAX_TOTAL_ATTACHMENT_MB=20
ALLOW_REMOTE_ATTACHMENTS=false
ALLOW_DATA_URI_ATTACHMENTS=true
ATTACHMENT_DOWNLOAD_TIMEOUT_SEC=30

# 可选：HTTP 模式配置
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000

# 可选：日志级别
# 常见值：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
