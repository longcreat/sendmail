# 必填：SMTP 基础配置
SMTP_HOST=smtp.example.com
SMTP_USERNAME=bot@example.com
SMTP_PASSWORD=replace_with_smtp_password

# 必填：收件人白名单（二选一）
# - 如需不限制收件域名，可设置 ALLOWED_RECIPIENT_DOMAINS=*
ALLOWED_RECIPIENT_DOMAINS=example.com
ALLOWED_RECIPIENTS=

# 可选：发件人地址（不填则默认使用 SMTP_USERNAME）
# MAIL_FROM=bot@example.com

# 可选：SMTP 端口与 TLS 模式（不填自动推断）
# - 端口 465: 默认 SSL
# - 端口 587: 默认 STARTTLS
SMTP_PORT=587
# SMTP_USE_SSL=false
# SMTP_USE_STARTTLS=true

# 可选：运行参数
RATE_LIMIT_EMAILS_PER_MIN=60
MAX_RECIPIENTS_PER_JOB=1000

# 可选：附件风控策略
ATTACHMENT_BASE_DIR=./attachments
MAX_ATTACHMENT_MB=5
MAX_TOTAL_ATTACHMENT_MB=20

# 可选：存储配置
DATABASE_URL=sqlite:///./data/sendmail.db

# 可选：MCP HTTP 配置
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000
LOG_LEVEL=INFO
